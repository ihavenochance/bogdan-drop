        .slot-info {
            margin-top: 25px;
            padding: 20px;
            background: rgba(0,0,0,0.6);
            border-radius: 25px;
            font-size: 1rem;
        }

        .slot-info p {
            margin: 8px 0;
            color: #ffd966;
        }

        .inventory-items { max-height: 450px; overflow-y: auto; margin-bottom: 20px; display: flex; flex-direction: column; gap: 10px; }
        .inventory-item { background: linear-gradient(95deg, #13172b, #0a0d18); border-radius: 20px; padding: 12px; display: flex; justify-content: space-between; align-items: center; border-left: 4px solid #ffd966; }
        .item-image { width: 50px; height: 50px; object-fit: contain; border-radius: 12px; cursor: pointer; }
        .item-info { display: flex; align-items: center; gap: 12px; flex: 1; }
        .item-name { font-weight: bold; color: #ffdd99; font-size: 0.85rem; }
        .item-level { font-size: 0.7rem; color: #8e9aaf; }
        .item-value { color: #ffd966; font-weight: bold; }
        .withdraw-btn { background: linear-gradient(135deg, #2a6f3a, #1a5f2a); border: none; padding: 6px 14px; border-radius: 20px; color: white; cursor: pointer; font-weight: bold; font-size: 0.8rem; }
        .withdraw-btn:disabled { background: #555; cursor: not-allowed; }

        .empty-inventory { text-align: center; color: #8e9aaf; padding: 40px; font-style: italic; }
        .deposit-section { margin-top: 16px; padding: 16px; background: linear-gradient(135deg, #0f1222cc, #070914cc); border-radius: 28px; border: 1px solid rgba(255, 215, 0, 0.2); }
        .deposit-buttons { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-top: 12px; }
        .deposit-btn { background: linear-gradient(135deg, #1a2a4a, #0f1a30); border: 1px solid #ffd966; border-radius: 40px; padding: 8px 16px; font-weight: bold; cursor: pointer; color: #ffeaac; flex: 1; min-width: 90px; font-size: 0.85rem; }
        .log-area { background: rgba(0, 0, 0, 0.7); border-radius: 24px; padding: 14px; font-size: 0.9rem; color: #b9c3db; text-align: center; margin-top: 16px; border-left: 4px solid #ffd966; }
        .progress-bar { width: 100%; height: 6px; background: rgba(0, 0, 0, 0.5); border-radius: 10px; overflow: hidden; margin-top: 8px; }
        .progress-fill { height: 100%; background: linear-gradient(90deg, #ffd966, #ffaa33); transition: width 0.3s; }

        .modal { display: none; position: fixed; z-index: 10000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.98); backdrop-filter: blur(15px); cursor: pointer; }
        .modal-content { margin: auto; display: block; width: 80%; max-width: 700px; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); }
        .modal-content img { width: 100%; border-radius: 20px; box-shadow: 0 0 80px rgba(255,215,0,0.6); }
        .close-modal { position: absolute; top: 20px; right: 35px; color: #ffd966; font-size: 50px; font-weight: bold; cursor: pointer; }

        .flash-effect { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle, rgba(255,215,0,0.4) 0%, rgba(255,215,0,0) 70%); pointer-events: none; z-index: 9999; animation: flash 0.6s ease-out; }
        @keyframes flash { 0% { opacity: 1; } 100% { opacity: 0; } }
        @keyframes spinReel { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        .reel-spinning { animation: spinReel 0.2s linear infinite; }

        .rarity-common { border-top: 3px solid #6a6f7e; }
        .rarity-uncommon { border-top: 3px solid #5f9c6b; }
        .rarity-rare { border-top: 3px solid #3a86ff; }
        .rarity-epic { border-top: 3px solid #aa6dc9; }
        .rarity-legendary { border-top: 3px solid #f7b32b; }
    </style>
</head>
