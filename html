        15:"SSG 08 | Смертельный выстрел",16:"★ Клинок-бабочка | Фадеон",17:"AWP | Дракон",18:"AK-47 | Золотое сияние",
        19:"M4A4 | Император",20:"★ Нож-бабочка | Лорд",21:"Божественный калаш | Мифический",
        22:"Космический дракон | Легенда",23:"★ Абсолют | Бесконечность",24:"✦ BOGDAN | ТИТАН ✦"
    };
    
    let currentLevel = 1, upgradeAttempts = 0, maxAchievedLevel = 1, coins = 1000, inventory = [];
    let isSpinning = false;
    
    // DOM элементы
    const weaponImage = document.getElementById("weaponImage"), weaponNameEl = document.getElementById("weaponName");
    const weaponLevelValue = document.getElementById("weaponLevelValue"), levelBadge = document.getElementById("levelBadge");
    const upgradeCountSpan = document.getElementById("upgradeCount"), maxLevelReachedSpan = document.getElementById("maxLevelReached");
    const coinsBalanceSpan = document.getElementById("coinsBalance"), logMessageDiv = document.getElementById("logMessage");
    const upgradeBtn = document.getElementById("upgradeBtn"), saveBtn = document.getElementById("saveBtn");
    const inventoryList = document.getElementById("inventoryList"), inventoryCountSpan = document.getElementById("inventoryCount");
    const totalValueSpan = document.getElementById("totalValue"), withdrawAllBtn = document.getElementById("withdrawAllBtn");
    const progressFill = document.getElementById("progressFill");
    const caseCoinsBalanceSpan = document.getElementById("caseCoinsBalance"), slotCoinsBalanceSpan = document.getElementById("slotCoinsBalance");
    const caseLogMessage = document.getElementById("caseLogMessage"), slotLogMessage = document.getElementById("slotLogMessage");
    const modal = document.getElementById("imageModal"), modalImage = document.getElementById("modalImage"), closeModal = document.querySelector(".close-modal");
    
    function getWeaponImageSrc(l){ return l+".png"; }
    function getWeaponValue(l){ return l * 40; }
    function addFlashEffect(){ const f=document.createElement('div'); f.className='flash-effect'; document.body.appendChild(f); setTimeout(()=>f.remove(),600); }
    function openModalImage(src){ modal.style.display="block"; modalImage.src=src; addFlashEffect(); }
    closeModal.onclick = () => modal.style.display = "none";
    window.onclick = (e) => { if(e.target == modal) modal.style.display = "none"; };
    weaponImage.onclick = () => openModalImage(getWeaponImageSrc(currentLevel));
    
    function getRarityClass(l){
        if(l<=5) return "rarity-common";
        if(l<=9) return "rarity-uncommon";
        if(l<=13) return "rarity-rare";
        if(l<=18) return "rarity-epic";
        return "rarity-legendary";
    }
    function toRoman(l){ if(l<=10){ const r=["","Ⅰ","Ⅱ","Ⅲ","Ⅳ","Ⅴ","Ⅵ","Ⅶ","Ⅷ","Ⅸ","Ⅹ"]; return r[l]; } return l.toString(); }
    function updateProgressBar(){ progressFill.style.width = (currentLevel/MAX_LEVEL*100)+"%"; }
    function setLogMessage(msg,isErr,isSucc, target=logMessageDiv){
        target.innerHTML = msg;
        target.style.borderLeftColor = isSucc ? "#4caf50" : (isErr ? "#e34d4d" : "#f5b042");
        target.style.backgroundColor = isSucc ? "#0a1f0faa" : (isErr ? "#2a0f0faa" : "#05070eaa");
        setTimeout(()=>{ if(target.innerHTML === msg) target.style.backgroundColor = "#05070eaa"; },3000);
    }
    
    function updateUI(){
        weaponImage.src = getWeaponImageSrc(currentLevel);
        weaponNameEl.textContent = weaponNames[currentLevel];
        weaponLevelValue.textContent = currentLevel;
        levelBadge.textContent = toRoman(currentLevel);
        upgradeCountSpan.textContent = upgradeAttempts;
        if(currentLevel > maxAchievedLevel) maxAchievedLevel = currentLevel;
        maxLevelReachedSpan.textContent = maxAchievedLevel+"/"+MAX_LEVEL;
        coinsBalanceSpan.textContent = Math.floor(coins);
        caseCoinsBalanceSpan.textContent = Math.floor(coins);
        slotCoinsBalanceSpan.textContent = Math.floor(coins);
        
        const oldRarity = Array.from(document.querySelector(".weapon-card").classList).find(c=>c.startsWith("rarity-"));
        if(oldRarity) document.querySelector(".weapon-card").classList.remove(oldRarity);
        document.querySelector(".weapon-card").classList.add(getRarityClass(currentLevel));
        updateProgressBar();
        
        if(currentLevel >= MAX_LEVEL){ upgradeBtn.innerHTML = "🏆 МАКСИМУМ 🏆"; upgradeBtn.disabled=true; }
        else { upgradeBtn.innerHTML = `💰 УЛУЧШИТЬ (${UPGRADE_COST} монет) 💰`; upgradeBtn.disabled = (coins < UPGRADE_COST); }
        updateInventoryUI();
    }
    
    function updateInventoryUI(){
        inventoryCountSpan.textContent = inventory.length;
        totalValueSpan.textContent = inventory.reduce((s,i)=>s+i.value,0);
        if(inventory.length === 0){ inventoryList.innerHTML = '<div class="empty-inventory">🎒 ИНВЕНТАРЬ ПУСТ</div>'; return; }
        inventoryList.innerHTML = inventory.map((item,idx)=>`
            <div class="inventory-item">
                <div class="item-info">
                    <img class="item-image" src="${item.image}" onclick="event.stopPropagation(); openModalImage('${item.image}')">
                    <div><div class="item-name">${item.name}</div><div class="item-level">Уровень ${item.level}/24</div></div>
                </div>
                <div style="display:flex; gap:8px; align-items:center;">
                    <div class="item-value">${item.value} 🪙</div>
                    <button class="withdraw-btn" onclick="withdrawItem(${idx})">💸 Вывести</button>
                </div>
            </div>
        `).join('');
    }
    
    window.withdrawItem = function(idx){
        if(idx>=inventory.length) return;
        const item = inventory[idx];
        const val = Math.floor(item.value * (1 - WITHDRAW_FEE));
        coins += val;
        inventory.splice(idx,1);
        updateUI();
        setLogMessage(`💰 ВЫВОД: +${val} монет за ${item.name}`, false, true);
    };
    
    function withdrawAll(){
        if(inventory.length === 0){ setLogMessage("❌ Инвентарь пуст", true); return; }
        let gain = 0;
        for(const item of inventory) gain += Math.floor(item.value * (1 - WITHDRAW_FEE));
        coins += gain;
        inventory = [];
        updateUI();
        setLogMessage(`💰 ВЫВОД ВСЕГО: +${gain} монет!`, false, true);
    }
    
    async function attemptUpgrade(){
        if(currentLevel >= MAX_LEVEL){ setLogMessage("❌ Максимальный уровень!", true); return; }
        if(coins < UPGRADE_COST){ setLogMessage(`💔 Нужно ${UPGRADE_COST} монет!`, true); return; }
        addFlashEffect();
        coins -= UPGRADE_COST;
        upgradeAttempts++;
        const oldLvl = currentLevel;
        const success = Math.random()*100 < baseSuccessRates[oldLvl-1];
        await new Promise(r=>setTimeout(r,200));
        if(success){ currentLevel = Math.min(currentLevel+1, MAX_LEVEL); setLogMessage(`✅ УСПЕХ! ${oldLvl} → ${currentLevel}`, false, true); }
        else { if(Math.random()*100 < 40 && currentLevel > 1){ currentLevel--; setLogMessage(`💔 ДАУНГРЕЙД! ${oldLvl} → ${currentLevel}`, true); }
        else { setLogMessage(`⚠️ НЕУДАЧА! Уровень ${oldLvl}`, false); } }
        updateUI();
        if(currentLevel === MAX_LEVEL) setLogMessage(`🏆 ТИТАН ДОСТИГНУТ! 🏆`, false, true);
    }
    
    async function saveToInventory(){
        if(currentLevel < MIN_SAVE_LEVEL){ setLogMessage(`❌ Нельзя сохранить ${currentLevel} уровень! Только с ${MIN_SAVE_LEVEL}+ уровня!`, true); return; }
        addFlashEffect();
        await new Promise(r=>setTimeout(r,200));
        inventory.push({ level: currentLevel, name: weaponNames[currentLevel], image: getWeaponImageSrc(currentLevel), value: getWeaponValue(currentLevel) });
        setLogMessage(`✅ СОХРАНЕНО! ${weaponNames[currentLevel]} (${getWeaponValue(currentLevel)} монет)`, false, true);
        currentLevel = 1;
        updateUI();
    }
    
    // Анимация для кейсов
    async function animateCase(cardElement) {
        cardElement.style.transform = "scale(0.95)";
        await new Promise(r=>setTimeout(r,100));
        cardElement.style.transform = "";
        const caseImg = cardElement.querySelector('img');
        caseImg.classList.add('case-spinning');
        await new Promise(r=>setTimeout(r,500));
        caseImg.classList.remove('case-spinning');
    }
    
    // Кейсы с анимацией
    async function openHomelessCase(){
        const card = document.querySelector('.case-card[data-case="homeless"]');
        await animateCase(card);
        if(coins < 200){ setLogMessage(`💔 Нужно 200 монет!`, true, false, caseLogMessage); return; }
        coins -= 200; updateUI(); addFlashEffect();
        
        // Анимация прокрутки картинок
        const caseImg = card.querySelector('img');
        for(let i = 0; i < 12; i++){
            await new Promise(r=>setTimeout(r,80));
            const randomLevel = Math.floor(Math.random() * 12) + 1;
            caseImg.src = getWeaponImageSrc(randomLevel);
        }
        
        const wonLevel = Math.floor(Math.random() * 12) + 1;
        const wonItem = { level: wonLevel, name: weaponNames[wonLevel], image: getWeaponImageSrc(wonLevel), value: getWeaponValue(wonLevel) };
        caseImg.src = wonItem.image;
        await new Promise(r=>setTimeout(r,300));
        
        setLogMessage(`🎉 БОМЖ КЕЙС: ${wonItem.name} (Ур.${wonLevel})!`, false, true, caseLogMessage);
        openModalImage(wonItem.image);
        const action = confirm(`🎉 Вам выпало: ${wonItem.name} (Уровень ${wonLevel})!\nСтоимость: ${wonItem.value} монет\n\nНажмите "ОК" чтобы СОХРАНИТЬ\n"Отмена" чтобы ЗАМЕНИТЬ`);
        if(action){ inventory.push(wonItem); setLogMessage(`✅ ${wonItem.name} сохранён!`, false, true, caseLogMessage); }
        else{ currentLevel = wonLevel; if(wonLevel > maxAchievedLevel) maxAchievedLevel = wonLevel; updateUI(); setLogMessage(`🔄 Заменено на ${wonItem.name}!`, false, true, caseLogMessage); }
        updateUI();
        setTimeout(()=>{ caseImg.src = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%238B4513'/%3E%3Ctext x='50' y='65' text-anchor='middle' fill='%23ffd966' font-size='45'%3E🎒%3C/text%3E%3C/svg%3E"; }, 2000);
    }
    
    async function openStandardCase(){
        const card = document.querySelector('.case-card[data-case="standard"]');
        await animateCase(card);
        if(coins < 500){ setLogMessage(`💔 Нужно 500 монет!`, true, false, caseLogMessage); return; }
        coins -= 500; updateUI(); addFlashEffect();
        
        const caseImg = card.querySelector('img');
        for(let i = 0; i < 15; i++){
            await new Promise(r=>setTimeout(r,70));
            const randomLevel = Math.floor(Math.random() * MAX_LEVEL) + 1;
            caseImg.src = getWeaponImageSrc(randomLevel);
        }
        
        const wonLevel = Math.floor(Math.random() * MAX_LEVEL) + 1;
        const wonItem = { level: wonLevel, name: weaponNames[wonLevel], image: getWeaponImageSrc(wonLevel), value: getWeaponValue(wonLevel) };
        caseImg.src = wonItem.image;
        await new Promise(r=>setTimeout(r,300));
        
        setLogMessage(`🎉 СТАНДАРТНЫЙ КЕЙС: ${wonItem.name} (Ур.${wonLevel})!`, false, true, caseLogMessage);
        openModalImage(wonItem.image);
        const action = confirm(`🎉 Вам выпало: ${wonItem.name} (Уровень ${wonLevel})!\nСтоимость: ${wonItem.value} монет\n\nНажмите "ОК" чтобы СОХРАНИТЬ\n"Отмена" чтобы ЗАМЕНИТЬ`);
        if(action){ inventory.push(wonItem); setLogMessage(`✅ ${wonItem.name} сохранён!`, false, true, caseLogMessage); }
        else{ currentLevel = wonLevel; if(wonLevel > maxAchievedLevel) maxAchievedLevel = wonLevel; updateUI(); setLogMessage(`🔄 Заменено на ${wonItem.name}!`, false, true, caseLogMessage); }
        updateUI();
        setTimeout(()=>{ caseImg.src = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%233a86ff'/%3E%3Ctext x='50' y='65' text-anchor='middle' fill='white' font-size='45'%3E📦%3C/text%3E%3C/svg%3E"; }, 2000);
    }
    
    async function openHighRiskCase(){
        const card = document.querySelector('.case-card[data-case="highrisk"]');
        await animateCase(card);
        if(coins < 500){ setLogMessage(`💔 Нужно 500 монет!`, true, false, caseLogMessage); return; }
        coins -= 500; updateUI(); addFlashEffect();
        
        const caseImg = card.querySelector('img');
        for(let i = 0; i < 10; i++){
            await new Promise(r=>setTimeout(r,100));
            const randomLevel = Math.random() < 0.66 ? 1 : 24;
            caseImg.src = getWeaponImageSrc(randomLevel);
        }
        
        const isOne = Math.random() * 100 < 66;
        const wonLevel = isOne ? 1 : 24;
        const wonItem = { level: wonLevel, name: weaponNames[wonLevel], image: getWeaponImageSrc(wonLevel), value: getWeaponValue(wonLevel) };
        caseImg.src = wonItem.image;
        await new Promise(r=>setTimeout(r,300));
        
        setLogMessage(`🎉 ДАДА/НЕТНЕТ: ${wonItem.name} (Ур.${wonLevel})!`, false, true, caseLogMessage);
        openModalImage(wonItem.image);
        const action = confirm(`🎉 Вам выпало: ${wonItem.name} (Уровень ${wonLevel})!\nСтоимость: ${wonItem.value} монет\n\nНажмите "ОК" чтобы СОХРАНИТЬ\n"Отмена" чтобы ЗАМЕНИТЬ`);
        if(action){ inventory.push(wonItem); setLogMessage(`✅ ${wonItem.name} сохранён!`, false, true, caseLogMessage); }
        else{ currentLevel = wonLevel; if(wonLevel > maxAchievedLevel) maxAchievedLevel = wonLevel; updateUI(); setLogMessage(`🔄 Заменено на ${wonItem.name}!`, false, true, caseLogMessage); }
        updateUI();
        setTimeout(()=>{ caseImg.src = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%23ff4444'/%3E%3Ctext x='50' y='65' text-anchor='middle' fill='white' font-size='45'%3E⚡%3C/text%3E%3C/svg%3E"; }, 2000);
    }
    
    // Рулетка с улучшенными шансами
    async function spinSlot(){
        if(isSpinning){ setLogMessage("⏳ Рулетка крутится...", false, false, slotLogMessage); return; }
        if(coins < 50){ setLogMessage(`💔 Нужно 50 монет!`, true, false, slotLogMessage); return; }
        coins -= 50; updateUI(); addFlashEffect();
        isSpinning = true;
        document.getElementById("spinSlotBtn").disabled = true;
        
        const reel1Img = document.getElementById("reel1Img"), reel2Img = document.getElementById("reel2Img");
        const reel3Img = document.getElementById("reel3Img"), reel1Level = document.getElementById("reel1Level");
        const reel2Level = document.getElementById("reel2Level"), reel3Level = document.getElementById("reel3Level");
        
        // Добавляем класс анимации
        reel1Img.classList.add('reel-spinning');
        reel2Img.classList.add('reel-spinning');
        reel3Img.classList.add('reel-spinning');
        
        // Увеличенное количество прокруток для азарта
        for(let spin = 0; spin < 20; spin++){
            await new Promise(r=>setTimeout(r,60));
            const r1 = Math.floor(Math.random() * MAX_LEVEL) + 1;
            const r2 = Math.floor(Math.random() * MAX_LEVEL) + 1;
            const r3 = Math.floor(Math.random() * MAX_LEVEL) + 1;
            reel1Img.src = getWeaponImageSrc(r1); reel1Level.textContent = `Уровень ${r1}`;
            reel2Img.src = getWeaponImageSrc(r2); reel2Level.textContent = `Уровень ${r2}`;
            reel3Img.src = getWeaponImageSrc(r3); reel3Level.textContent = `Уровень ${r3}`;
        }
        
        // Повышенные шансы на одинаковые уровни
        let final1, final2, final3;
        const jackpotChance = Math.random() * 100;
        
        if(jackpotChance < 8){ // 8% шанс на джекпот (вместо 0.02%)
            const jackpotLevel = Math.floor(Math.random() * MAX_LEVEL) + 1;
            final1 = final2 = final3 = jackpotLevel;
            setLogMessage(`🎰 ВЫПАЛ ДЖЕКПОТ! 🎰`, false, false, slotLogMessage);
        } else {
            final1 = Math.floor(Math.random() * MAX_LEVEL) + 1;
            final2 = Math.floor(Math.random() * MAX_LEVEL) + 1;
            final3 = Math.floor(Math.random() * MAX_LEVEL) + 1;
            // 15% шанс что два будут одинаковыми
            if(Math.random() * 100 < 15){
                final2 = final1;
            }
            if(Math.random() * 100 < 15){
                final3 = final1;
            }
        }
        
        reel1Img.classList.remove('reel-spinning');
        reel2Img.classList.remove('reel-spinning');
        reel3Img.classList.remove('reel-spinning');
        
        reel1Img.src = getWeaponImageSrc(final1); reel1Level.textContent = `Уровень ${final1}`;
        reel2Img.src = getWeaponImageSrc(final2); reel2Level.textContent = `Уровень ${final2}`;
        reel3Img.src = getWeaponImageSrc(final3); reel3Level.textContent = `Уровень ${final3}`;
        
        if(final1 === final2 && final2 === final3){
            const winAmount = getWeaponValue(final1) * 10;
            coins += winAmount;
            updateUI();
            setLogMessage(`🎰 ДЖЕКПОТ! Три ${final1} уровня! Выигрыш: ${winAmount} монет! 🎰`, false, true, slotLogMessage);
            openModalImage(getWeaponImageSrc(final1));
            addFlashEffect();
        } else if(final1 === final2 || final2 === final3 || final1 === final3){
            setLogMessage(`🎰 Два совпадения! Почти джекпот... (${final1}, ${final2}, ${final3})`, false, false, slotLogMessage);
        } else {
            setLogMessage(`🎰 Выпало: ${final1}, ${final2}, ${final3} - Нет совпадений...`, false, false, slotLogMessage);
        }
        
        isSpinning = false;
        document.getElementById("spinSlotBtn").disabled = false;
    }
    
    function processPayment(priceUSD, coinsAdd){
        return new Promise(resolve => {
            setLogMessage(`💳 Оплата $${priceUSD}...`, false);
            setTimeout(() => { coins += coinsAdd; updateUI(); setLogMessage(`✅ +${coinsAdd} монет!`, false, true); resolve(); }, 800);
        });
    }
    async function addCoins(coinsAmount, priceUSD){ if(priceUSD <= 0) return; await processPayment(priceUSD, coinsAmount); }
    
    // Обработчики
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById(`tab-${btn.dataset.tab}`).classList.add('active');
        });
    });
    
    document.querySelectorAll('.case-card').forEach(card => {
        card.addEventListener('click', () => {
            const type = card.dataset.case;
            if(type === 'homeless') openHomelessCase();
            else if(type === 'standard') openStandardCase();
            else if(type === 'highrisk') openHighRiskCase();
        });
    });
    
    upgradeBtn.onclick = attemptUpgrade;
    saveBtn.onclick = saveToInventory;
    withdrawAllBtn.onclick = withdrawAll;
    document.getElementById("spinSlotBtn").onclick = spinSlot;
    
    document.querySelectorAll('.deposit-btn').forEach(btn => {
        btn.onclick = async () => { await addCoins(parseInt(btn.dataset.coins), parseFloat(btn.dataset.price)); };
    });
    
    updateUI();
    setLogMessage("🔥 ДОБРО ПОЖАЛОВАТЬ В BOGDAN DROP! 🔥", false, true);
</script>
</body>
