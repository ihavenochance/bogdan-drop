        .upgrade-btn { background: linear-gradient(135deg, #2a7f2a, #1a5f1a); color: #ffdd99; box-shadow: 0 5px 0 #0a3a0a; }
        .upgrade-btn:active { transform: translateY(3px); box-shadow: 0 2px 0 #0a3a0a; }
        .save-btn { background: linear-gradient(135deg, #ff8800, #cc6600); color: white; box-shadow: 0 5px 0 #884400; }
        .save-btn:active { transform: translateY(3px); box-shadow: 0 2px 0 #884400; }
        .withdraw-all-btn { background: linear-gradient(135deg, #ff4444, #cc0000); color: white; box-shadow: 0 5px 0 #880000; }
        .withdraw-all-btn:active { transform: translateY(3px); box-shadow: 0 2px 0 #880000; }
        .upgrade-btn:disabled, .save-btn:disabled { opacity: 0.5; transform: none; cursor: not-allowed; }

        .case-container {
            background: rgba(10, 12, 20, 0.9);
            border-radius: 28px;
            border: 1px solid rgba(255, 215, 0, 0.2);
            padding: 30px;
            text-align: center;
            max-width: 1200px;
            margin: 0 auto;
        }

        .cases-grid {
            display: flex;
            gap: 25px;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 30px;
        }

        .case-card {
            background: linear-gradient(145deg, #13172b, #0a0d18);
            border-radius: 28px;
            padding: 20px;
            width: 280px;
            cursor: pointer;
            transition: all 0.2s;
            border: 2px solid rgba(255, 215, 0, 0.3);
        }

        .case-card:hover { transform: translateY(-5px); border-color: #ffd966; box-shadow: 0 10px 30px rgba(255,215,0,0.2); }
        .case-card img { width: 150px; height: 150px; margin: 10px auto; display: block; }
        .case-card h3 { color: #ffd966; margin: 15px 0 10px; }
        .case-card p { color: #8e9aaf; font-size: 0.9rem; margin: 5px 0; }

        /* Анимация для кейсов */
        @keyframes caseSpin {
            0% { transform: scale(1) rotate(0deg); }
            25% { transform: scale(1.1) rotate(90deg); }
            50% { transform: scale(1.2) rotate(180deg); }
            75% { transform: scale(1.1) rotate(270deg); }
            100% { transform: scale(1) rotate(360deg); }
        }

        .case-spinning {
            animation: caseSpin 0.5s ease-in-out;
        }

        /* Слот машина увеличенная */
        .slot-container {
            background: rgba(10, 12, 20, 0.9);
            border-radius: 28px;
            border: 1px solid rgba(255, 215, 0, 0.2);
            padding: 30px;
            text-align: center;
            max-width: 1100px;
            margin: 0 auto;
        }

        .slot-machine {
            background: linear-gradient(145deg, #1a1e30, #0e1120);
            border-radius: 40px;
            padding: 40px;
            margin: 20px 0;
        }

        .slot-reels {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-bottom: 40px;
            flex-wrap: wrap;
        }

        .slot-reel {
            background: #0a0d18;
            border-radius: 25px;
            padding: 25px;
            width: 220px;
            text-align: center;
            border: 3px solid #ffd966;
            box-shadow: 0 0 30px rgba(255,215,0,0.3);
        }

        .slot-reel img {
