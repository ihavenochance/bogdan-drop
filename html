        .stat span:last-child { color: #ffdf8c; font-weight: 800; font-size: 1.2rem; }
        .balance { background: linear-gradient(135deg, rgba(255, 215, 0, 0.15), rgba(255, 136, 0, 0.1)); border: 1px solid #ffd966; }

        .weapon-card {
