            border-radius: 36px;
            padding: 25px 20px;
            text-align: center;
            margin-bottom: 20px;
            border: 1px solid rgba(255, 200, 50, 0.3);
        }

        .weapon-image {
            width: 100%;
            max-width: 450px;
            height: auto;
            min-height: 350px;
            object-fit: contain;
            margin: 0 auto;
            display: block;
            filter: drop-shadow(0 8px 20px rgba(0,0,0,0.6));
            cursor: pointer;
            background: linear-gradient(145deg, #1a1e30, #0e1120);
            border-radius: 20px;
        }

        .weapon-name { font-size: 1.3rem; font-weight: 700; background: linear-gradient(135deg, #fff5e0, #ffd966); -webkit-background-clip: text; background-clip: text; color: transparent; margin-top: 15px; }
        .weapon-level { display: inline-block; margin-top: 12px; background: rgba(0, 0, 0, 0.7); padding: 8px 24px; border-radius: 60px; font-weight: bold; font-size: 1rem; color: #ffcd7e; border: 1px solid #ffcd7e55; }

        .upgrade-btn, .save-btn, .case-btn, .withdraw-all-btn, .spin-slot-btn {
            width: 100%;
            border: none;
            padding: 16px;
            font-size: 1.2rem;
            font-weight: 800;
            border-radius: 60px;
            cursor: pointer;
            margin-bottom: 12px;
            font-family: inherit;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.1s ease;
