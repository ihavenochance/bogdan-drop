        }

        .stats-panel {
            display: flex;
            justify-content: space-between;
            background: linear-gradient(135deg, #0f111acc, #080a12cc);
            border-radius: 60px;
            padding: 8px 20px;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 10px;
            border: 1px solid rgba(255, 215, 0, 0.2);
